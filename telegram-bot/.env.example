# Monthly Key Telegram Bot — Environment Variables
# Copy this file to .env and fill in the values

# ─── Required ─────────────────────────────────────────────────
BOT_TOKEN=your_telegram_bot_token_here
OPENAI_API_KEY=your_openai_api_key_here

# ─── Optional: URLs ──────────────────────────────────────────
API_BASE_URL=https://monthlykey.com/api/trpc
WEBAPP_URL=https://tg.monthlykey.com
WEBSITE_URL=https://monthlykey.com

# ─── Phase 2: Payment ────────────────────────────────────────
# Get from @BotFather → Payments → Connect a provider (Stripe, etc.)
PAYMENT_PROVIDER_TOKEN=

# ─── Phase 3: Admin ──────────────────────────────────────────
# Comma-separated Telegram user IDs that have admin access
# Find your ID by messaging @userinfobot on Telegram
ADMIN_IDS=123456789,987654321

# ─── Phase 3: Channel Auto-Posting ───────────────────────────
# Channel ID (e.g., @monthlykey_channel or -1001234567890)
# Bot must be added as admin to the channel
CHANNEL_ID=
# How often to check for new listings (in milliseconds, default 300000 = 5 min)
CHANNEL_CHECK_INTERVAL=300000
